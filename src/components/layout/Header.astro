---
import { Image } from 'astro:assets';
import { NAV, SITE_NAME, REGISTRATION_URL } from '@/consts';
import MobileMenu from './MobileMenu.astro';
import logoImg from '@/assets/logo/logo_transparent.png';

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---

<header class="site-header" role="banner">
  <div class="container site-header__inner">
    <a href="/" class="site-logo" aria-label={`${SITE_NAME} — strona główna`}>
      <Image
        src={logoImg}
        alt={SITE_NAME}
        widths={[200, 360, 460]}
        sizes="(min-width: 48em) 230px, 180px"
        loading="eager"
        fetchpriority="high"
        class="site-logo__img"
      />
    </a>

    <nav class="site-nav" aria-label="Główna nawigacja">
      <ul role="list">
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['site-nav__link', { active: isActive(item.href) }]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <a
      href={REGISTRATION_URL}
      class="btn btn--primary btn--sm site-header__cta"
      target="_blank"
      rel="noopener"
      aria-label="Zapisz się na kurs (otwiera formularz Google w nowej karcie)"
    >
      Zapisz się na kurs
    </a>

    <MobileMenu />
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-line-soft);
    /* No backdrop-filter here: it would become the containing block for the
       position:fixed mobile menu and collapse it to zero height. The blur
       lives on ::before instead, which is not a DOM ancestor of the menu. */
  }

  .site-header::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    height: 68px;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-ink);
    flex: 0 0 auto;
    margin-right: auto;
    padding: 4px 2px;
    border-radius: var(--radius-sm);
    transition: opacity var(--dur-xs) var(--ease-out);
  }

  .site-logo:hover { opacity: 0.85; }

  :global(.site-logo__img) {
    display: block;
    width: auto;
    height: 40px;
    max-width: 200px;
    object-fit: contain;
  }

  @media (min-width: 48em) {
    :global(.site-logo__img) {
      height: 48px;
      max-width: 230px;
    }
  }

  .site-nav {
    display: none;
  }

  @media (min-width: 64em) {
    .site-nav {
      display: block;
    }
  }

  .site-nav ul {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav__link {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.85rem;
    border-radius: var(--radius-md);
    color: var(--color-ink-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: var(--fs-sm);
    transition: background var(--dur-xs) var(--ease-out), color var(--dur-xs) var(--ease-out);
  }

  .site-nav__link:hover {
    color: var(--color-ink);
    background: var(--color-bg-soft);
  }

  .site-nav__link.active {
    color: var(--color-primary-700);
    background: var(--color-primary-50);
  }

  .site-header__cta {
    display: none;
  }

  @media (min-width: 48em) {
    .site-header__cta {
      display: inline-flex;
    }
  }

  /* Button styles — keep co-located here too (shared with Button.astro). */
  :global(.btn) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: var(--fs-sm);
    text-decoration: none;
    line-height: 1;
    transition: background var(--dur-xs) var(--ease-out),
                color var(--dur-xs) var(--ease-out),
                transform var(--dur-xs) var(--ease-out),
                box-shadow var(--dur-xs) var(--ease-out);
    white-space: nowrap;
  }

  :global(.btn--primary) {
    background: var(--color-primary-600);
    color: #fff;
    box-shadow: 0 1px 0 var(--color-primary-700) inset, var(--shadow-sm);
  }

  :global(.btn--primary:hover) {
    background: var(--color-primary-700);
    transform: translateY(-1px);
    box-shadow: 0 1px 0 var(--color-primary-800) inset, var(--shadow-md);
  }

  :global(.btn--secondary) {
    background: var(--color-bg);
    color: var(--color-primary-700);
    border: 1.5px solid var(--color-primary-200);
  }

  :global(.btn--secondary:hover) {
    border-color: var(--color-primary-600);
    background: var(--color-primary-50);
  }

  :global(.btn--ghost) {
    background: transparent;
    color: var(--color-ink);
  }

  :global(.btn--ghost:hover) {
    background: var(--color-bg-soft);
  }

  :global(.btn--sm) { padding: 0.55rem 1rem; font-size: 0.875rem; }
  :global(.btn--lg) { padding: 0.95rem 1.75rem; font-size: var(--fs-md); }

  :global(.btn--block) { display: flex; width: 100%; }
</style>
