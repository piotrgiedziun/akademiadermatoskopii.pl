---
/**
 * Homepage hero. Copy supplied by the academy (strona AD.docx).
 */
import { Image } from 'astro:assets';
import { REGISTRATION_URL } from '@/consts';
import Button from '@/components/ui/Button.astro';
import instructorImg from '@/assets/instructors/jacek-calik.jpg';

const HERO = {
  kicker: 'Szkoła dermatoskopii dla lekarzy',
  title: 'Z nami nauczysz się więcej widzieć i trafniej diagnozować',
  subtitle:
    'Akademia Dermatoskopii to praktyczne szkolenia prowadzone we Wrocławiu pod kierownictwem merytorycznym dr hab. n. med. Jacka Calika.',
  courseTypes: [
    'Kursy dermatoskopowe na wszystkich poziomach zaawansowania',
    'Kursy z chirurgii skóry',
    'Kursy z trudnych lokalizacji',
    'Kursy z pisania prac naukowych',
    'Kursy z lasera CO2',
  ],
};
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <span class="eyebrow">{HERO.kicker}</span>
      <h1 class="hero__title text-balance">{HERO.title}</h1>
      <p class="hero__subtitle text-pretty">{HERO.subtitle}</p>
      <ul class="hero__course-types" role="list">
        {HERO.courseTypes.map((type) => (
          <li>
            <span class="hero__course-tick" aria-hidden="true">✓</span>
            {type}
          </li>
        ))}
      </ul>
      <div class="hero__actions">
        <Button href={REGISTRATION_URL} external ariaLabel="Zapisz się na kurs (otwiera formularz Google w nowej karcie)">
          Zapisz się na kurs
        </Button>
        <Button href="/kursy/" variant="secondary">
          Zobacz harmonogram 2026
        </Button>
      </div>
      <dl class="hero__stats">
        <div>
          <dt>absolwentów</dt>
          <dd>2300+</dd>
        </div>
        <div>
          <dt>edycji rocznie</dt>
          <dd>14</dd>
        </div>
        <div>
          <dt>lat doświadczenia</dt>
          <dd>10+</dd>
        </div>
      </dl>
    </div>
    <figure class="hero__visual">
      <div class="hero__orb hero__orb--a" aria-hidden="true"></div>
      <div class="hero__orb hero__orb--b" aria-hidden="true"></div>
      <div class="hero__portrait">
        <Image
          src={instructorImg}
          alt="dr hab. n. med. Jacek Calik — założyciel Akademii Dermatoskopii"
          widths={[220, 440, 600]}
          sizes="(min-width: 64em) 380px, 280px"
          loading="eager"
          fetchpriority="high"
          class="hero__portrait-img"
        />
        <figcaption class="hero__caption">
          <strong>dr hab. n. med. Jacek Calik</strong>
          <span>Założyciel Akademii Dermatoskopii</span>
        </figcaption>
      </div>
    </figure>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-2xl) var(--space-xl);
    background:
      radial-gradient(ellipse at 15% 0%, var(--color-primary-50) 0%, transparent 50%),
      radial-gradient(ellipse at 100% 100%, color-mix(in srgb, var(--color-accent-500) 15%, transparent) 0%, transparent 45%),
      var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 64em) {
    .hero {
      padding-block: var(--space-3xl) var(--space-2xl);
    }
  }

  .hero__inner {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 64em) {
    .hero__inner {
      grid-template-columns: 1.3fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 600;
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin-block: var(--space-2xs) var(--space-xs);
  }

  .hero__subtitle {
    font-size: var(--fs-md);
    color: var(--color-ink-muted);
    line-height: var(--leading-snug);
    max-width: 48ch;
  }

  .hero__course-types {
    list-style: none;
    padding: 0;
    margin: var(--space-md) 0 0;
    display: grid;
    gap: var(--space-2xs);
    max-width: 52ch;
  }

  .hero__course-types li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2xs);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--color-ink);
  }

  .hero__course-tick {
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    margin-top: 0.05rem;
    border-radius: var(--radius-pill);
    background: var(--color-primary-50);
    color: var(--color-primary-700);
    font-size: 0.7rem;
    font-weight: 700;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-lg);
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: var(--space-md) var(--space-xl);
    margin-top: var(--space-xl);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-line);
    max-width: 520px;
  }

  .hero__stats dt {
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    order: 2;
  }

  .hero__stats dd {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--color-primary-700);
    margin: 0;
    order: 1;
  }

  .hero__stats > div {
    display: flex;
    flex-direction: column;
  }

  .hero__visual {
    position: relative;
    aspect-ratio: 1;
    max-width: 440px;
    margin-inline: auto;
    margin-block: 0;
    display: grid;
    place-items: center;
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.55;
  }

  .hero__orb--a {
    width: 70%;
    height: 70%;
    top: 5%;
    left: 5%;
    background: color-mix(in srgb, var(--color-primary-500) 40%, transparent);
  }

  .hero__orb--b {
    width: 55%;
    height: 55%;
    bottom: 0;
    right: 0;
    background: color-mix(in srgb, var(--color-accent-500) 40%, transparent);
  }

  .hero__portrait {
    position: relative;
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    padding: 0;
    overflow: hidden;
    max-width: 380px;
    width: 100%;
    margin: 0;
  }

  :global(.hero__portrait-img) {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    object-position: top center;
  }

  .hero__caption {
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    line-height: 1.35;
    text-align: left;
    background:
      linear-gradient(180deg, rgba(255,255,255,0) 0%, #fff 30%);
    position: relative;
    margin-top: -40px;
  }

  .hero__caption strong {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--color-ink);
  }

  .hero__caption span {
    font-size: var(--fs-sm);
    color: var(--color-ink-muted);
  }
</style>
