---
/**
 * Renders a hero image from any of:
 *   - an Astro-optimized import (ImageMetadata) — hand-authored posts;
 *   - a "/src/assets/…" path — CMS uploads (Sveltia saves into src/ and writes a
 *     /src/… path; we resolve it back to an import so it's optimized too);
 *   - any other URL string (e.g. legacy /images/… public paths) — plain <img>.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  widths = [400, 720, 1200],
  sizes,
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;

// Lazy map of every src/assets image so a "/src/assets/…" string can be
// resolved to an optimizable import at build time.
const srcAssets = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/**/*.{jpeg,jpg,png,gif,webp,avif}',
);

let optimized: ImageMetadata | null = typeof src === 'string' ? null : src;
if (typeof src === 'string' && src.startsWith('/src/') && srcAssets[src]) {
  optimized = (await srcAssets[src]!()).default;
}
const fallbackSrc = typeof src === 'string' ? src : src.src;
---

{optimized ? (
  <Image src={optimized} alt={alt} widths={widths} sizes={sizes} loading={loading} fetchpriority={fetchpriority} class={className} />
) : (
  <img src={fallbackSrc} alt={alt} loading={loading} fetchpriority={fetchpriority} decoding="async" class={className} />
)}
