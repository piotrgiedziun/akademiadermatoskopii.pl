---
/**
 * Renders a hero image that may be either an Astro-optimized import
 * (ImageMetadata, from src/assets) or a plain public URL string (from
 * /images/…, uploaded via the CMS — Sveltia requires public-folder paths).
 * Optimized imports go through <Image>; strings render as a plain <img>.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

export interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
}

const {
  src,
  alt,
  widths = [400, 720, 1200],
  sizes,
  loading = 'lazy',
  fetchpriority,
  class: className,
} = Astro.props;
---

{typeof src === 'string' ? (
  <img src={src} alt={alt} loading={loading} fetchpriority={fetchpriority} decoding="async" class={className} />
) : (
  <Image src={src} alt={alt} widths={widths} sizes={sizes} loading={loading} fetchpriority={fetchpriority} class={className} />
)}
