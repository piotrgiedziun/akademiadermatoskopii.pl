---
/**
 * SEO meta tags — renders the <head> surface for any page.
 * Emits: canonical, OG, Twitter, hreflang, JSON-LD (via <JsonLd>).
 */
import { SITE_URL, SITE_NAME, TITLE_SUFFIX, DEFAULT_OG } from '@/consts';
import JsonLd from './JsonLd.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  ogImageAlt?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  schema?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage = DEFAULT_OG,
  ogImageAlt,
  publishedTime,
  modifiedTime,
  noindex = false,
  schema,
} = Astro.props;

const fullTitle = title.includes(SITE_NAME) ? title : `${title}${TITLE_SUFFIX}`;
const currentUrl = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString();
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).toString();
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={currentUrl} />

{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={currentUrl} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="pl_PL" />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}

{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

{/* hreflang */}
<link rel="alternate" hreflang="pl-PL" href={currentUrl} />
<link rel="alternate" hreflang="x-default" href={currentUrl} />

{/* JSON-LD */}
{schema && <JsonLd data={schema} />}
