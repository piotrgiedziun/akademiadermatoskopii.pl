---
/**
 * Emit JSON-LD safely. Escapes `</script>` sequences to prevent HTML injection.
 * Accepts a single object or an array of schema objects.
 */
interface Props {
  data: Record<string, any> | Record<string, any>[];
}

const { data } = Astro.props;
const payloads = Array.isArray(data) ? data : [data];

function serialize(obj: Record<string, any>): string {
  return JSON.stringify(obj).replace(/</g, '\\u003c');
}
---

{payloads.map((p) => (
  <script is:inline type="application/ld+json" set:html={serialize(p)} />
))}
