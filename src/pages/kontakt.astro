---
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/util/Breadcrumbs.astro';
import ContactBlock from '@/components/content/ContactBlock.astro';
import RegistrationCta from '@/components/content/RegistrationCta.astro';
import { medicalBusinessSchema, breadcrumbSchema } from '@/components/seo/schema';
import { ADDRESS } from '@/lib/siteData';

const title = 'Kontakt';
const description =
  'Kontakt z Akademią Dermatoskopii — ul. Wyspiańskiego 11, Wrocław. E-mail: kontakt@akademiadermatoskopii.pl.';

const schema = [
  medicalBusinessSchema(),
  breadcrumbSchema([
    { label: 'Strona główna', href: '/' },
    { label: 'Kontakt', href: '/kontakt/' },
  ]),
];
---

<PageLayout title={title} description={description} schema={schema}>
  <div class="container page-head">
    <Breadcrumbs crumbs={[{ label: 'Kontakt', href: '/kontakt/' }]} />
    <span class="eyebrow">Kontakt</span>
    <h1>Porozmawiajmy</h1>
  </div>

  <section class="section">
    <div class="container">
      <ContactBlock />
    </div>
  </section>

  <section class="section section-soft" aria-labelledby="h-map">
    <div class="container">
      <div class="section-heading">
        <span class="eyebrow">Lokalizacja</span>
        <h2 id="h-map">Znajdziesz nas we Wrocławiu</h2>
        <p>Akademia mieści się przy {ADDRESS.full}. Najlepiej dojechać tramwajem lub samochodem.</p>
      </div>
      <div class="map-wrap">
        <a
          href={ADDRESS.mapsUrl}
          target="_blank"
          rel="noopener"
          class="map-link"
          aria-label="Otwórz lokalizację w Mapach Google"
        >
          <div class="map-placeholder">
            <svg viewBox="0 0 24 24" width="48" height="48" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z" />
            </svg>
            <span>{ADDRESS.full}</span>
            <small>Kliknij aby otworzyć w Mapach Google →</small>
          </div>
        </a>
      </div>
    </div>
  </section>

  <RegistrationCta />
</PageLayout>

<style>
  .page-head {
    padding-block: var(--space-xl) var(--space-lg);
  }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    margin-block: var(--space-2xs) var(--space-sm);
    letter-spacing: -0.02em;
  }
  .page-intro {
    color: var(--color-ink-muted);
    font-size: var(--fs-md);
    max-width: 60ch;
    line-height: 1.55;
  }

  .section-heading {
    max-width: 48ch;
    margin-bottom: var(--space-xl);
  }
  .section-heading h2 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    margin-top: var(--space-xs);
    margin-bottom: var(--space-sm);
  }
  .section-heading p {
    color: var(--color-ink-muted);
  }

  .map-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: var(--color-bg);
  }

  .map-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: background var(--dur-xs) var(--ease-out);
  }

  .map-link:hover { background: var(--color-primary-50); }

  .map-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
    text-align: center;
    gap: var(--space-sm);
    color: var(--color-primary-700);
    background:
      repeating-linear-gradient(45deg, var(--color-primary-50), var(--color-primary-50) 10px, var(--color-bg) 10px, var(--color-bg) 20px);
    min-height: 300px;
  }

  .map-placeholder span {
    font-weight: 600;
    font-size: var(--fs-md);
    color: var(--color-ink);
  }

  .map-placeholder small {
    color: var(--color-ink-muted);
    font-size: var(--fs-sm);
  }
</style>
