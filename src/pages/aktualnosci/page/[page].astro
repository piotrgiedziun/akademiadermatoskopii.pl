---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/util/Breadcrumbs.astro';
import NewsCard from '@/components/content/NewsCard.astro';
import Pagination from '@/components/util/Pagination.astro';
import { NEWS_PAGE_SIZE } from '@/lib/news';
import { SITE_URL } from '@/consts';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection('news', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
  );
  // Generate /aktualnosci/page/N/ for pages 2..N — page 1 is served by index.astro
  return paginate(posts, { pageSize: NEWS_PAGE_SIZE }).filter(
    (p) => Number(p.params.page) >= 2,
  );
};

type Props = { page: Page<CollectionEntry<'news'>> };
const { page } = Astro.props as Props;
const currentPage = page.currentPage;
const totalPages = page.lastPage;

const title = `Aktualności — strona ${currentPage}`;
const description = `Strona ${currentPage} z ${totalPages} — aktualności Akademii Dermatoskopii.`;
const canonical = new URL(`/aktualnosci/page/${currentPage}/`, SITE_URL).toString();
---

<PageLayout title={title} description={description} canonical={canonical} noindex={false}>
  <div class="container page-head">
    <Breadcrumbs
      crumbs={[
        { label: 'Aktualności', href: '/aktualnosci/' },
        { label: `Strona ${currentPage}`, href: `/aktualnosci/page/${currentPage}/` },
      ]}
    />
    <span class="eyebrow">Blog i relacje</span>
    <h1>Aktualności <span class="page-head__page">— strona {currentPage}</span></h1>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-auto">
        {page.data.map((p) => <NewsCard post={p} />)}
      </div>

      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        basePath="/aktualnosci/"
        totalItems={page.total}
        pageSize={page.size}
      />
    </div>
  </section>
</PageLayout>

<style>
  .page-head {
    padding-block: var(--space-xl) var(--space-lg);
  }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    margin-block: var(--space-2xs) var(--space-sm);
  }
  .page-head__page {
    color: var(--color-ink-soft);
    font-weight: 400;
  }
</style>
