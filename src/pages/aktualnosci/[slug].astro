---
import { getCollection, getEntry, render } from 'astro:content';
import HeroImage from '@/components/util/HeroImage.astro';
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/util/Breadcrumbs.astro';
import Callout from '@/components/ui/Callout.astro';
import FormattedDate from '@/components/util/FormattedDate.astro';
import CourseCard from '@/components/content/CourseCard.astro';
import YouTubeEmbed from '@/components/content/YouTubeEmbed.astro';
import { articleSchema } from '@/components/seo/schema';
import { SITE_URL } from '@/consts';

export async function getStaticPaths() {
  const posts = await getCollection('news', ({ data }) => !data.draft);
  return posts.map((p) => ({
    params: { slug: p.id },
    props: { post: p },
  }));
}

const { post } = Astro.props;
const d = post.data;
const { Content } = await render(post);

const pageUrl = new URL(`/aktualnosci/${post.id}/`, SITE_URL).toString();

const title = d.seo.title ?? d.title;
const description = d.seo.description ?? d.summary;

const author = d.author ? await getEntry('instructors', d.author.id) : null;
const relatedCourses = await Promise.all(
  d.relatedCourses.map((ref) => getEntry('courses', ref.id)),
);

const schema = articleSchema(post, pageUrl);
---

<PageLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={d.publishedAt}
  modifiedTime={d.updatedAt}
  schema={schema}
>
  <div class="container article">
    <Breadcrumbs
      crumbs={[
        { label: 'Aktualności', href: '/aktualnosci/' },
        { label: d.title, href: `/aktualnosci/${post.id}/` },
      ]}
    />

    <article>
      <header class="article__head">
        <div class="article__meta">
          <FormattedDate date={d.publishedAt} />
          {author && <span> · {author.data.titlePrefix} {author.data.name}</span>}
          {d.tags.length > 0 && (
            <span class="article__tags">
              {d.tags.map((t) => <span class="article__tag">{t}</span>)}
            </span>
          )}
        </div>
        <h1 class="article__title">{d.title}</h1>
        <p class="article__lede">{d.summary}</p>
      </header>

      {d.youtubeId ? (
        <div class="article__video">
          <YouTubeEmbed id={d.youtubeId} title={d.title} />
        </div>
      ) : d.heroImage && (
        <figure class="article__hero">
          <HeroImage
            src={d.heroImage}
            alt={d.heroImageAlt ?? d.title}
            widths={[600, 1000, 1400]}
            sizes="(min-width: 64em) 860px, 100vw"
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      )}

      <div class="prose">
        <Content components={{ callout: Callout }} />
      </div>
    </article>

    {relatedCourses.length > 0 && (
      <aside class="article__related" aria-labelledby="h-related">
        <h2 id="h-related">Zobacz także</h2>
        <div class="grid-auto">
          {relatedCourses.map((c) => c && <CourseCard course={c} />)}
        </div>
      </aside>
    )}
  </div>
</PageLayout>

<style>
  .article {
    padding-block: var(--space-xl) var(--space-2xl);
    max-width: 900px;
  }

  .article__head {
    margin-block: var(--space-lg) var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-line);
  }

  .article__meta {
    color: var(--color-ink-soft);
    font-size: var(--fs-sm);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .article__tags {
    display: inline-flex;
    gap: 0.3rem;
  }

  .article__tag {
    display: inline-block;
    background: var(--color-primary-50);
    color: var(--color-primary-700);
    padding: 0.15em 0.6em;
    border-radius: var(--radius-pill);
    font-size: var(--fs-xs);
    font-weight: 500;
  }

  .article__title {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    margin-block: var(--space-xs) var(--space-md);
    max-width: 26ch;
  }

  .article__lede {
    font-size: var(--fs-lg);
    color: var(--color-ink-muted);
    line-height: 1.5;
    max-width: 62ch;
  }

  .article__hero {
    margin: 0 0 var(--space-xl);
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
    box-shadow: var(--shadow-md);
  }

  .article__hero :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article__video {
    margin: 0 0 var(--space-xl);
  }

  .article__related {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-line);
  }

  .article__related h2 {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    margin-bottom: var(--space-lg);
  }
</style>
