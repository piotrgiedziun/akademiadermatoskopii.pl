---
import PageLayout from '@/layouts/PageLayout.astro';
import Breadcrumbs from '@/components/util/Breadcrumbs.astro';
import NewsCard from '@/components/content/NewsCard.astro';
import Pagination from '@/components/util/Pagination.astro';
import { getCollection } from 'astro:content';
import { NEWS_PAGE_SIZE } from '@/lib/news';

const allPosts = (await getCollection('news', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const totalPages = Math.max(1, Math.ceil(allPosts.length / NEWS_PAGE_SIZE));
const posts = allPosts.slice(0, NEWS_PAGE_SIZE);

const title = 'Aktualności';
const description =
  'Nowości z Akademii Dermatoskopii — premiery kursów, relacje z warsztatów, aktualizacje platformy SKINTEST i wiadomości z projektów badawczych.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Aktualności — Akademia Dermatoskopii',
  description,
};
---

<PageLayout title={title} description={description} schema={schema}>
  <div class="container page-head">
    <Breadcrumbs crumbs={[{ label: 'Aktualności', href: '/aktualnosci/' }]} />
    <span class="eyebrow">Blog i relacje</span>
    <h1>Aktualności</h1>
    <p class="page-intro">
      Najnowsze informacje o kursach, projektach i działalności Akademii Dermatoskopii.
    </p>
  </div>

  <section class="section">
    <div class="container">
      <div class="grid-auto">
        {posts.map((p) => <NewsCard post={p} />)}
      </div>

      <Pagination
        currentPage={1}
        totalPages={totalPages}
        basePath="/aktualnosci/"
        totalItems={allPosts.length}
        pageSize={NEWS_PAGE_SIZE}
      />
    </div>
  </section>
</PageLayout>

<style>
  .page-head {
    padding-block: var(--space-xl) var(--space-lg);
  }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-3xl);
    margin-block: var(--space-2xs) var(--space-sm);
  }
  .page-intro {
    color: var(--color-ink-muted);
    font-size: var(--fs-md);
    max-width: 64ch;
  }
</style>
